# WordPress REST API Configuration
# Copy this file to .env and fill in your values.

# WordPress site URL (e.g. https://example.com)
VITE_WP_URL=

# WooCommerce Consumer Key & Secret (from WooCommerce > Settings > Advanced > REST API)
VITE_WC_CONSUMER_KEY=
VITE_WC_CONSUMER_SECRET=

# JWT Token for authenticated requests (optional, used with JWT Auth plugin)
VITE_JWT_TOKEN=
